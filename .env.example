# Convex Configuration
# Get these from your Convex dashboard at https://dashboard.convex.dev
VITE_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:your-deploy-key

# Auth Configuration (used by Convex Auth)
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-min-32-characters

# Site URL (used for OAuth callbacks)
SITE_URL=http://localhost:5000

# Optional: OAuth Providers
# Uncomment and fill in if using OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
