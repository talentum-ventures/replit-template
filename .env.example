# Local development values
# In most cases you do not create this file by hand.
# `npx convex dev --once --local` writes the real values to `.env.local`.

CONVEX_DEPLOYMENT=local:your-local-deployment
VITE_CONVEX_URL=http://127.0.0.1:3210
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# Convex backend environment values
# These are set in Convex, not committed to your repo.
SITE_URL=http://localhost:5000

# Optional Google OAuth values stored in Convex
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
#
# Optional dev-only Google emulation endpoint stored in Convex:
# `npm run setup` or the Replit first-run setup sets this automatically.
# Local Convex dev can reach emulate directly.
# AUTH_GOOGLE_EMULATE_URL=http://localhost:4002
#
# Replit workspace dev should use the public Vite proxy URL because the browser
# cannot follow auth redirects to the container's localhost directly.
# AUTH_GOOGLE_EMULATE_URL=https://your-replit-domain.replit.dev/google-emulate
#
# Do not set this in production. When unset, Convex Auth uses the real Google provider.

# Production note:
# Replit deployments should provide `CONVEX_DEPLOY_KEY` and production
# `VITE_CONVEX_URL` through Replit environment variables or secrets.
