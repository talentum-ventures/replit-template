modules = ["nodejs-20", "web"]
run = "npm run dev:all"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 4002
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

[deployment]
deploymentTarget = "static"
publicDir = "dist/public"
build = ["bash", "-lc", "npx convex deploy && npm run build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:all"
waitForPort = 5000

[[workflows.workflow]]
name = "Setup"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run setup"
